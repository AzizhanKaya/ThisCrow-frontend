{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "thiscrow",
	"version": "0.1.0",
	"identifier": "com.thiscrow.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build-only"
	},
	"app": {
		"windows": [
			{
				"title": "ThisCrow",
				"width": 1200,
				"height": 800,
				"minWidth": 910,
				"minHeight": 300,
				"resizable": true,
				"decorations": false,
				"transparent": true,
				"shadow": true,
				"userAgent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	},
	"plugins": {
		"updater": {
			"active": true,
			"pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY",
			"endpoints": ["https://github.com/AzizhanKaya/ThisCrow/releases/latest/download/latest.json"]
		}
	}
}
