{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "thiscrow",
	"version": "0.1.0",
	"identifier": "com.thiscrow.desktop",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "app",
				"title": "ThisCrow",
				"width": 1200,
				"height": 800,
				"minWidth": 910,
				"minHeight": 300,
				"resizable": true,
				"decorations": false,
				"transparent": true,
				"shadow": true,
				"visible": false
			}
		],
		"security": {
			"csp": null,
			"dangerousDisableAssetCspModification": true
		},
		"macOSPrivateApi": true
	},
	"bundle": {
		"createUpdaterArtifacts": true,
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	},
	"plugins": {
		"updater": {
			"active": true,
			"endpoints": ["https://github.com/AzizhanKaya/ThisCrow-frontend/releases/latest/download/latest.json"],
			"windows": {
				"targets": ["passive"]
			},
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzQkQzMzI5RkQxODVFODMKUldTRFhoajlLVE85c3kwM0xqQ1JYYmk0MmRnekdLbEl3TDFqRUdhaDNMS1lnRG5maEJ6NDFsS1AK"
		}
	}
}
