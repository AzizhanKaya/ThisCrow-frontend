{
  "name": "thiscrow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:wasm": "cd wasm-lib && cargo watch -w src -s \"wasm-pack build . --target web --out-dir ../pkg\"",
    "dev": "concurrently -c \"cyan,magenta\" \"pnpm run dev:frontend\" \"pnpm run dev:wasm\"",
    "build:wasm": "cd wasm-lib && wasm-pack build . --target web --out-dir ../pkg",
    "prebuild": "pnpm run build:wasm",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@msgpack/msgpack": "^3.1.3",
    "@tanstack/vue-virtual": "^3.13.13",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@vueuse/core": "^13.1.0",
    "canonical-json": "^0.2.0",
    "dexie": "^4.2.1",
    "fast-json-stable-stringify": "^2.1.0",
    "gsap": "^3.14.2",
    "json-bigint": "^1.0.0",
    "pinia": "^3.0.3",
    "uuid": "^11.1.0",
    "vue-router": "^4.5.0",
    "vue-virtual-scroller": "2.0.0-beta.8",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@iconify/iconify": "^3.1.1",
    "@iconify/json": "^2.2.455",
    "@tsconfig/node22": "^22.0.1",
    "@types/fast-json-stable-stringify": "^2.1.2",
    "@types/json-bigint": "^1.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue-macros/reactivity-transform": "^3.1.2",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "msw": "^2.7.5",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vite-plugin-purge-icons": "^0.10.0",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue": "^3.5.30",
    "vue-tsc": "^2.2.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}